# DocOps Agent environment template
# Copy to .env and adjust:
#   cp .env.example .env

# ============================================================
# Required
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET_KEY=replace_with_a_long_random_secret

# ============================================================
# Runtime
# ============================================================
DOCOPS_ENV=development
LOG_LEVEL=INFO

# ============================================================
# Database and auth
# ============================================================
DATABASE_URL=sqlite:///./data/app.db
DB_MIGRATIONS_ENABLED=true
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# ============================================================
# Paths
# ============================================================
CHROMA_DIR=./data/chroma
BM25_DIR=./data/bm25
DOCS_DIR=./docs
UPLOADS_DIR=./uploads
ARTIFACTS_DIR=./artifacts

# ============================================================
# CORS (set explicit allow-list in production)
# ============================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=true

# ============================================================
# Ingest guardrails
# ============================================================
INGEST_ALLOWED_DIRS=./docs
INGEST_UPLOAD_MAX_BYTES=26214400
INGEST_PHOTO_MAX_BYTES=10485760

# ============================================================
# Retrieval and RAG
# ============================================================
TOP_K=6
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_MODE=mmr
MIN_RELEVANCE_SCORE=0.2
MMR_FETCH_K=24
MMR_LAMBDA=0.5
CONTEXT_MAX_CHARS=1500
MULTI_QUERY=false
MULTI_QUERY_N=3
MULTI_QUERY_PER_QUERY_K=6
RERANKER=none
RERANK_TOP_N=6
HYBRID_K_LEX=6
HYBRID_ALPHA=0.5
INGEST_INCREMENTAL=false
STRUCTURED_CHUNKING=true

# ============================================================
# Model routing
# ============================================================
GEMINI_MODEL_ROUTER_ENABLED=true
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_COMPLEX=gemini-3-flash-preview
GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite-preview
GEMINI_MODEL_QA_SIMPLE=gemini-2.5-flash

# ============================================================
# Grounding and retries
# ============================================================
SEMANTIC_GROUNDING_ENABLED=true
GROUNDED_CLAIMS_MODE=heuristic
GROUNDED_VERIFIER_MODE=heuristic
GROUNDED_VERIFIER_THRESHOLD=0.65
MIN_SUPPORT_RATE=0.5
MAX_RETRIES=2
MIN_CITATIONS=2
GROUNDING_REPAIR_MAX_PASSES=1
GROUNDING_RETRIEVAL_MAX_RETRIES=1
SEMANTIC_GROUNDING_MAX_CLAIMS=24
SEMANTIC_GROUNDING_MAX_CHUNKS=12
SEMANTIC_GROUNDING_MAX_EVIDENCE_CHARS=1600
DEBUG_GROUNDING=false

# ============================================================
# Deep summary
# ============================================================
SUMMARY_DEEP_PROFILE=balanced
SUMMARY_MAX_CORRECTIVE_PASSES=1
SUMMARY_STYLE_POLISH_ENABLED=false
SUMMARY_FINAL_GATE_ENABLED=false
SUMMARY_FAIL_CLOSED_STRICT=true
SUMMARY_MIN_UNIQUE_SOURCES=5
SUMMARY_MAX_INFERENCE_DENSITY=0.25
SUMMARY_GROUP_SIZE=8
SUMMARY_MAX_GROUPS=6
SUMMARY_SECTION_THRESHOLD=0.70
SUMMARY_MAX_SOURCES=12
SUMMARY_GROUNDING_THRESHOLD=0.20
SUMMARY_GROUNDING_REPAIR=false
SUMMARY_FORMULA_MODE=conservative
SUMMARY_LATENCY_BUDGET_SECONDS=300

# ============================================================
# Eval harness
# ============================================================
EVAL_SUITES_DIR=./eval/suites
EVAL_OUTPUT_DIR=./artifacts
