# DocOps Agent — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Segredo JWT — obrigatório para iniciar o servidor com autenticação.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-por-um-segredo-aleatorio-longo

# ── Banco de dados ────────────────────────────────────────────────────────────

# SQLite local (padrão — desenvolvimento):
# DATABASE_URL=sqlite:///./data/app.db
#
# PostgreSQL (produção):
# DATABASE_URL=postgresql+psycopg2://usuario:senha@localhost:5432/docops
#
# Para migrar SQLite → Postgres:
#   1. pip install psycopg2-binary
#   2. Configure DATABASE_URL acima
#   3. Rode: alembic upgrade head  (ou deixe a app criar as tabelas no startup)

# ── Auth (opcionais) ──────────────────────────────────────────────────────────

# Validade do access token (minutos, padrão: 60)
# JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# ── Segurança de ingest por path ─────────────────────────────────────────────

# Diretórios permitidos para POST /api/ingest (ingest por path no servidor).
# Separe por vírgula. Padrão: apenas DOCS_DIR.
# INGEST_ALLOWED_DIRS=./docs,/mnt/shared
# INGEST_UPLOAD_MAX_BYTES=26214400
# INGEST_PHOTO_MAX_BYTES=10485760

# ── Paths (optional — defaults shown) ────────────────────────────────────────

# Directory where ChromaDB persists its index
CHROMA_DIR=./data/chroma

# Directory containing documents to ingest (PDF, MD, TXT)
DOCS_DIR=./docs

# Directory where generated artifacts are saved
ARTIFACTS_DIR=./artifacts

# ── RAG tuning (optional) ─────────────────────────────────────────────────────

# Number of chunks retrieved per query
TOP_K=6

# Token size of each document chunk
CHUNK_SIZE=900

# Overlap between consecutive chunks (tokens)
CHUNK_OVERLAP=150

# ── Logging ───────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Retrieval quality ─────────────────────────────────────────────────────────

# Retrieval mode: "mmr" (diverse, default) or "similarity" (pure cosine)
RETRIEVAL_MODE=mmr

# Minimum relevance score — chunks below this threshold are discarded.
# Range: 0.0 (accept everything) to 1.0 (require exact match). Default: 0.2
MIN_RELEVANCE_SCORE=0.2

# MMR fetch_k: how many candidates to fetch before MMR re-ranking (default: top_k * 4)
# MMR_FETCH_K=24

# MMR lambda: 0.0 = max diversity, 1.0 = max relevance (default: 0.5)
# MMR_LAMBDA=0.5

# Max chars of chunk text injected into the LLM context block.
# 0 = no limit (use full text). Default: 1500
# CONTEXT_MAX_CHARS=1500

# ── Retrieval mode: "mmr" (default), "similarity", or "hybrid" (BM25 + vector)
# RETRIEVAL_MODE=mmr

# ── Multi-query retrieval (increases recall via query rewriting) ─────────────

# Enable multi-query: rewrites the query into N variations and merges results
# MULTI_QUERY=false

# Number of query variations to generate
# MULTI_QUERY_N=3

# top_k per individual query variation
# MULTI_QUERY_PER_QUERY_K=6

# ── Reranking ────────────────────────────────────────────────────────────────

# Reranker mode: "none" (default), "local" (fast bag-of-words), "llm" (Gemini)
# RERANKER=none

# How many documents to keep after reranking
# RERANK_TOP_N=6

# ── Hybrid search (BM25 + vector) ───────────────────────────────────────────

# Directory to persist BM25 index
# BM25_DIR=./data/bm25

# Number of BM25 (lexical) results in hybrid mode
# HYBRID_K_LEX=6

# Weight balance (reserved for future use; RRF used by default)
# HYBRID_ALPHA=0.5

# ── Incremental ingestion ───────────────────────────────────────────────────

# Skip re-indexing unchanged chunks (uses stable SHA-256 IDs)
# INGEST_INCREMENTAL=false

# ── Advanced / optional ───────────────────────────────────────────────────────

# Deterministic model router by task
# GEMINI_MODEL_ROUTER_ENABLED=true
#
# Base fallback model (used when router is disabled or route is unknown)
# GEMINI_MODEL=gemini-2.5-flash
#
# Route "complex":
# - deep summary synthesis/consolidation/finalization
# - graph intents: summary (deep), comparison, study_plan, checklist
# GEMINI_MODEL_COMPLEX=gemini-3-flash-preview
#
# Route "cheap":
# - intent classification, query rewrites, rerank_llm
# - semantic grounding (claims/support), lightweight validators/repairs
# - graph intent: summary (brief)
# GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite-preview
#
# Route "qa_simple":
# - direct Q&A synthesis and grounding repair text generation
# - graph intent: qa (and unknown intents fallback)
# GEMINI_MODEL_QA_SIMPLE=gemini-2.5-flash

# Maximum number of retrieval retry attempts when grounding check fails
# MAX_RETRIES=2

# Minimum number of cited sources required to pass grounding check
# MIN_CITATIONS=2

# ── Structured chunking ────────────────────────────────────────────────────────

# Enable heading-aware splitters for .md/.txt
# STRUCTURED_CHUNKING=true

# ── Semantic grounding verifier ────────────────────────────────────────────────

# Master switch for semantic grounding
# SEMANTIC_GROUNDING_ENABLED=true

# Claim extraction mode: heuristic | llm | hybrid
# GROUNDED_CLAIMS_MODE=heuristic

# Evidence support checker mode: heuristic | llm | hybrid
# GROUNDED_VERIFIER_MODE=heuristic

# Heuristic threshold for SUPPORTED label
# GROUNDED_VERIFIER_THRESHOLD=0.65

# Minimum support rate before repair/retry logic
# MIN_SUPPORT_RATE=0.5

# Max semantic repair passes (default 1)
# GROUNDING_REPAIR_MAX_PASSES=1

# Max retrieval retries triggered by semantic grounding (default 1)
# GROUNDING_RETRIEVAL_MAX_RETRIES=1

# Expose grounding block in API/CLI debug mode
# DEBUG_GROUNDING=false

# ── Eval harness ───────────────────────────────────────────────────────────────

# Directory containing eval YAML suites
# EVAL_SUITES_DIR=./eval/suites

# Directory where eval JSON reports are written
# EVAL_OUTPUT_DIR=./artifacts

# Deep summary quality gates
# Deep summary execution profile (recommended default):
# fast | balanced | model_first | strict
# SUMMARY_DEEP_PROFILE=balanced
#
# SUMMARY_MIN_UNIQUE_SOURCES=5
# SUMMARY_RESYNTHESIS_WEAK_BLOCK_RATIO=0.50
# SUMMARY_RESYNTHESIS_MAX_WEAK_RATIO_DEGRADATION=0.05
# SUMMARY_NOTATION_REQUIRE_VARIABLE_LEGEND=true
# SUMMARY_CLAIM_LOCAL_REPAIR_ENABLED=false
# SUMMARY_FINAL_GATE_ENABLED=false
# SUMMARY_FAIL_CLOSED_STRICT=true

# Runtime / CORS hardening
# DOCOPS_ENV=development
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin
# CORS_ALLOW_CREDENTIALS=true
